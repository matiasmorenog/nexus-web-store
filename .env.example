# Copiá este archivo a `.env` y completá los valores.
# En local, para levantar cada tienda sin editar `.env`: `npm run dev:app1` o `npm run dev:app2`

# =============================================================================
# BASE DE DATOS
# =============================================================================

# Runtime (Neon pooled). Host con "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connection_limit=1&pgbouncer=true"

# Migraciones, seed y build (Neon direct). Sin "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Docker local (alternativa): misma URL en ambas variables
# DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus_web_store"
# DIRECT_URL="postgresql://nexus:nexus@localhost:5432/nexus_web_store"

# =============================================================================
# AUTH Y URL PÚBLICA
# =============================================================================

# Generar: openssl rand -base64 32
AUTH_SECRET="generar-con-openssl-rand-base64-32"

# URL base de este deploy (sin barra final).
# Local con npm run dev:        http://localhost:3000
# Local con npm run dev:app2:   http://localhost:3001
# Vercel:                       https://tu-proyecto.vercel.app
AUTH_URL="http://localhost:3000"

# Misma URL que AUTH_URL (links en emails, checkout, MP).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth (login cliente + admin). Crear credenciales en Google Cloud Console.
# Redirect URI autorizada: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =============================================================================
# TIENDA ACTIVA (slug — NO va en .env)
# =============================================================================
#
# Slugs en código y DB, no en este archivo:
#   - prisma/seed-env.ts → SEED_STORES (filas Store en Neon)
#   - src/lib/store-slugs.ts → APP1_STORE_SLUG, APP2_STORE_SLUG
#
# Local: `npm run dev:app1` (demo-store :3000) o `npm run dev:app2` (vape-demo :3001)
# El script scripts/dev-store.sh exporta slug + AUTH_URL por perfil.
# `npm run dev` sin perfil → fallback demo-store (store-slugs.ts).
#
# Vercel: cada proyecto setea DEFAULT_STORE_SLUG en el dashboard del deploy
# (no copiar acá). Ver DEPLOY.md.

# =============================================================================
# INTEGRACIONES
# =============================================================================

# Subir fotos en admin (mismo token que Vercel Production)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Emails transaccionales (remitente = nombre tienda + email owner en DB)
RESEND_API_KEY="re_..."

# Pagos Mercado Pago (sin esto: checkout en modo demo)
# Podés configurarlo en Admin → Configuración o vía variable de entorno (fallback).
# MERCADOPAGO_ACCESS_TOKEN="TEST-..."

# Cifrado de tokens guardados por el admin (opcional; si omitís, usa AUTH_SECRET)
# PAYMENT_SECRETS_KEY="generar-con-openssl-rand-base64-32"

# Cotización envíos Mercado Envíos (sin token: cotización demo por zonas CP)
# Preferí configurarlo en Admin → Módulos → Envíos carrier (self-service, cifrado).
# Fallback: token de Mercado Pago en Admin → Cobros. Legacy servidor:
# MERCADOENVIOS_ACCESS_TOKEN="..."

# AFIP — facturación electrónica (fase posterior; config por tienda en Admin → API)
# Homologación: https://wswhomo.afip.gov.ar/wsfev1/service.asmx
# Producción:   https://servicios1.afip.gov.ar/wsfev1/service.asmx
# Certificado .crt + clave .key por tienda (pendiente integración WS en src/lib/afip/)
# AFIP_CERT_PATH=""
# AFIP_KEY_PATH=""

# =============================================================================
# MÓDULOS ADMIN (plan base + Plus)
# =============================================================================
# Lista separada por comas. IDs en src/lib/modules/catalog.ts y docs/modules-pricing.md
# Omitir o vacío = todos los módulos activos (demo app1). Solo plan base: ENABLED_MODULES=none
# App2 producción (beta): ENABLED_MODULES=none en Vercel. App1 demo: omitir variable.
# Ejemplo parcial: ENABLED_MODULES=coupons,homeEditor,analytics

# ENABLED_MODULES=

# =============================================================================
# SEED Y DATOS DEMO
# =============================================================================
# Config (slugs, owners, passwords): prisma/seed-env.ts
#
# npm run db:seed:app1   → solo Goat / demo-store (limpia y recrea esa tienda)
# npm run db:seed:app2      → solo Cloud / vape-demo
# npm run db:seed / db:seed:all → ambas tiendas a la vez
# npm run db:wipe:app1   → borra solo demo-store (sin re-seed)
# npm run db:wipe:app2      → borra solo vape-demo
# npm run db:setup          → schema + seed ambas + pedidos demo app1
