# Copiá a .env y completá los valores.

# Runtime (Neon pooled + Prisma serverless). Host debe incluir "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connection_limit=1&pgbouncer=true"

# Migraciones / db:push / seed desde tu máquina (Neon "Direct connection", sin -pooler).
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

AUTH_SECRET="generar-con-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Tienda activa (obligatorio en runtime; debe coincidir con el slug en DB)
DEFAULT_STORE_SLUG="alaska-indumentaria"

# Contacto público y avisos de venta (al menos uno obligatorio para /contacto)
NEXT_PUBLIC_CONTACT_EMAIL="contacto@tutienda.com"
STORE_NOTIFICATION_EMAIL="admin@tutienda.com"

# Solo desarrollo: prellena email en /admin/login (opcional)
NEXT_PUBLIC_ADMIN_DEMO_EMAIL="admin@tutienda.com"

# Solo seed (npm run db:setup) — override para otra tienda demo
# SEED_STORE_NAME="Alaska"
# SEED_ADMIN_EMAIL="admin@tutienda.com"
# SEED_ADMIN_PASSWORD="admin123"
# SEED_ADMIN_NAME="Admin"

# Local con Docker (docker compose up -d): misma URL en ambas variables
# DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus_web_store"
# DIRECT_URL="postgresql://nexus:nexus@localhost:5432/nexus_web_store"
