# Copiá este archivo a `.env` y completá los valores.
# En local, para levantar cada tienda sin editar `.env`: `npm run dev:apparel` o `npm run dev:vape`

# =============================================================================
# BASE DE DATOS
# =============================================================================

# Runtime (Neon pooled). Host con "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connection_limit=1&pgbouncer=true"

# Migraciones, seed y build (Neon direct). Sin "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Docker local (alternativa): misma URL en ambas variables
# DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus_web_store"
# DIRECT_URL="postgresql://nexus:nexus@localhost:5432/nexus_web_store"

# =============================================================================
# AUTH Y URL PÚBLICA
# =============================================================================

# Generar: openssl rand -base64 32
AUTH_SECRET="generar-con-openssl-rand-base64-32"

# URL base de este deploy (sin barra final).
# Local con npm run dev:        http://localhost:3000
# Local con npm run dev:vape:   http://localhost:3001
# Vercel:                       https://tu-proyecto.vercel.app
AUTH_URL="http://localhost:3000"

# Misma URL que AUTH_URL (links en emails, checkout, MP).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# TIENDA ACTIVA (un conjunto por proceso local o por proyecto Vercel)
# =============================================================================
#
# El mismo repo puede servir varias tiendas. Cada deploy elige UNA fila en `Store`
# (por slug) y UNA vertical (ropa vs vape). Los slugs del seed están en
# `prisma/seed-env.ts` → SEED_STORES.
#
# ── STORE_VERTICAL ───────────────────────────────────────────────────────────
# Dónde: servidor (RSC, layout, queries, emails).
# Qué define: home, catálogo, nav, labels de variantes, tokens UI, metadata.
# Valores permitidos:
#   apparel  → catálogo completo, filtros, promo 2x1, género, talle/color
#   vape     → home-only (sin /productos), +18, sabor/nicotina, sin 2x1
# Si omitís: apparel
#
# ── VAPE_STOREFRONT_MODE (solo deploy vape) ──────────────────────────────────
# Opcional. Valores: home-only (default en config) | full
#   full → activa /productos, búsqueda y filtros nicotina/sabor sin cambiar código.
# Dejalo sin definir en producción mientras el catálogo sea chico (vitrina en home).
#
# ── NEXT_PUBLIC_STORE_VERTICAL ─────────────────────────────────────────────
# Dónde: navegador (componentes "use client": admin, carrito, checkout).
# Debe ser IGUAL que STORE_VERTICAL en el mismo deploy.
# Valores permitidos: apparel | vape
#
# ── DEFAULT_STORE_SLUG ───────────────────────────────────────────────────────
# Qué fila `Store` lee este deploy (nombre, envío, owner, productos).
# Valores tras `npm run db:setup` (ver seed-env.ts):
#   demo-store   → tienda apparel (Goat)
#   vape-demo    → tienda vape (Cloud)
# Si omitís: demo-store
#
# Combinaciones válidas (deploy / local):
#   apparel + demo-store   → tienda de ropa
#   vape    + vape-demo    → tienda vape
#
# No mezclar (ej. STORE_VERTICAL=vape con DEFAULT_STORE_SLUG=demo-store): la UI
# sería vape pero los productos y el admin serían de la otra tienda.
#
# En local, `npm run dev:apparel` y `npm run dev:vape` setean estas tres vars
# (y AUTH_URL / NEXT_PUBLIC_APP_URL) sin tocar este archivo.
# Para las dos a la vez: `npm run dev:both` (puertos 3000 + 3001).

STORE_VERTICAL=apparel
NEXT_PUBLIC_STORE_VERTICAL=apparel
DEFAULT_STORE_SLUG=demo-store

# Perfil vape (referencia; usá npm run dev:vape o descomentá para dev manual):
# STORE_VERTICAL=vape
# NEXT_PUBLIC_STORE_VERTICAL=vape
# DEFAULT_STORE_SLUG=vape-demo
# AUTH_URL=http://localhost:3001
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# =============================================================================
# INTEGRACIONES
# =============================================================================

# Subir fotos en admin (mismo token que Vercel Production)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Emails transaccionales (remitente = nombre tienda + email owner en DB)
RESEND_API_KEY="re_..."

# Pagos Mercado Pago (sin esto: checkout en modo demo)
# MERCADOPAGO_ACCESS_TOKEN="TEST-..."

# Cotización envíos Mercado Envíos (sin esto: modo demo)
# MERCADOENVIOS_ACCESS_TOKEN="..."

# =============================================================================
# SEED Y DATOS DEMO
# =============================================================================
# Config (slugs, owners, passwords): prisma/seed-env.ts
#
# npm run db:seed:apparel   → solo Goat / demo-store (limpia y recrea esa tienda)
# npm run db:seed:vape      → solo Cloud / vape-demo
# npm run db:seed / db:seed:all → ambas tiendas a la vez
# npm run db:wipe:apparel   → borra solo demo-store (sin re-seed)
# npm run db:wipe:vape      → borra solo vape-demo
# npm run db:setup          → schema + seed ambas + pedidos demo apparel
