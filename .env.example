# Copiá a .env y completá los valores.

# ── Obligatorias (local y Vercel Production) ────────────────────────

# Neon pooled — runtime. Host con "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connection_limit=1&pgbouncer=true"

# Neon direct — build Vercel, migraciones y seed. Sin "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

AUTH_SECRET="generar-con-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Subir fotos en admin (mismo token que Vercel Production)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Emails transaccionales (remitente = nombre tienda + email owner en DB)
RESEND_API_KEY="re_..."

# Seed: editá prisma/seed-env.ts (slug, nombre, owner, password admin)

# ── Opcional ───────────────────────────────────────────────────────
# MERCADOPAGO_ACCESS_TOKEN="TEST-..."          # pagos reales (sin esto: demo)

# Docker local: misma URL en DATABASE_URL y DIRECT_URL
# DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus_web_store"
# DIRECT_URL="postgresql://nexus:nexus@localhost:5432/nexus_web_store"
