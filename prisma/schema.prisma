generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  STORE_OWNER
  STORE_STAFF
  CUSTOMER
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum MercadoEnviosStatus {
  READY_TO_SHIP
  IN_TRANSIT
  DELIVERED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Coupon {
  id             String     @id @default(cuid())
  storeId        String
  code           String
  type           CouponType
  value          Decimal
  minOrderAmount Decimal    @default(0)
  maxDiscount    Decimal?
  usageLimit     Int?
  usedCount      Int        @default(0)
  startsAt       DateTime?
  expiresAt      DateTime?
  active         Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([storeId, code])
  @@index([storeId, active])
}

model Store {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  logo             String?
  primaryColor     String   @default("#171717")
  secondaryColor   String   @default("#f5f5f5")
  shippingFlatRate Decimal  @default(0)
  allowPickup      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users    UserStore[]
  products Product[]
  orders            Order[]
  coupons           Coupon[]
  homeContent       StoreHomeContent?
  customers         StoreCustomer[]
  seoSettings       StoreSeoSettings?
  wishlistItems     WishlistItem[]
  marketingSettings StoreMarketingSettings?
  shippingSettings  StoreShippingSettings?
  themeSettings     StoreThemeSettings?
  apiKeys           StoreApiKey[]
  webhookSettings   StoreWebhookSettings?
  promotionSettings StorePromotionSettings?
}

model StorePromotionSettings {
  storeId         String   @id
  promo2x1Enabled Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreThemeSettings {
  storeId                  String   @id
  themeId                  String   @default("default")
  allowCustomerThemeToggle Boolean  @default(true)
  updatedAt                DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreApiKey {
  id         String    @id @default(cuid())
  storeId    String
  name       String
  keyPrefix  String
  keyHash    String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([keyHash])
}

model StoreWebhookSettings {
  storeId   String   @id
  enabled   Boolean  @default(false)
  url       String?
  secret    String?
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreMarketingSettings {
  storeId          String   @id
  whatsappEnabled  Boolean  @default(false)
  whatsappPhone    String?
  whatsappMessage  String?
  metaPixelEnabled Boolean  @default(false)
  metaPixelId      String?
  updatedAt        DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreShippingSettings {
  storeId            String   @id
  carriersEnabled    Boolean  @default(true)
  preferredCarrierId String   @default("mercado_envios")
  updatedAt          DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreHomeContent {
  id        String   @id @default(cuid())
  storeId   String   @unique
  version   Int      @default(1)
  payload   Json
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreCustomer {
  id        String   @id @default(cuid())
  storeId   String
  email     String
  tags      String[] @default([])
  notes     String   @default("")
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email])
  @@index([storeId])
}

model StoreSeoSettings {
  storeId                 String   @id
  metaDescription         String?
  ogImageUrl              String?
  robotsIndex             Boolean  @default(true)
  structuredDataEnabled   Boolean  @default(true)
  updatedAt               DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model WishlistItem {
  id        String   @id @default(cuid())
  storeId   String
  userId    String
  productId String
  createdAt DateTime @default(now())

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId, productId])
  @@index([storeId, productId])
  @@index([storeId, userId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(STORE_OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stores UserStore[]
  orders Order[]
  wishlistItems WishlistItem[]
}

model UserStore {
  id      String @id @default(cuid())
  userId  String
  storeId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model Product {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  slug        String
  description String
  category    String
  audience    String   @default("unisex")
  featured    Boolean  @default(false)
  promo2x1    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store         Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants      ProductVariant[]
  wishlistItems WishlistItem[]

  @@unique([storeId, slug])
  @@index([storeId, createdAt(sort: Desc)])
  @@index([storeId, featured])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  size      String
  color     String
  sku       String
  stock     Int      @default(0)
  price     Decimal
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([productId, size, color])
}

model Order {
  id              String      @id @default(cuid())
  storeId         String
  userId          String?
  status          OrderStatus @default(PENDING)
  total           Decimal
  promoDiscount   Decimal     @default(0)
  couponId        String?
  couponCode      String?
  couponDiscount  Decimal     @default(0)
  shippingCost    Decimal     @default(0)
  customerName    String
  customerEmail   String
  customerPhone   String
  isPickup        Boolean     @default(false)
  shippingAddress String
  shippingCity    String
  shippingZip     String
  mpPreferenceId            String?
  mpPaymentId               String?
  meShipmentId              String?
  meTrackingNumber          String?
  meTrackingUrl             String?
  meCarrier                 String?
  meStatus                  MercadoEnviosStatus?
  meEstimatedDelivery       DateTime?
  confirmationEmailSentAt   DateTime?
  createdAt                 DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  store  Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user   User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  coupon Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items  OrderItem[]

  @@index([storeId, createdAt(sort: Desc)])
  @@index([storeId, status, createdAt])
  @@index([storeId, userId, createdAt(sort: Desc)])
  @@index([storeId, customerEmail, createdAt(sort: Desc)])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int
  unitPrice Decimal

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
}
