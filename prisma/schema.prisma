generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  STORE_OWNER
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

model Store {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  logo             String?
  primaryColor     String   @default("#171717")
  secondaryColor   String   @default("#f5f5f5")
  domain           String?
  shippingFlatRate Decimal  @default(0)
  allowPickup      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users    UserStore[]
  products Product[]
  orders   Order[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(STORE_OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stores UserStore[]
}

model UserStore {
  id      String @id @default(cuid())
  userId  String
  storeId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model Product {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  slug        String
  description String
  category    String
  audience    String   @default("unisex")
  featured    Boolean  @default(false)
  promo2x1    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@unique([storeId, slug])
  @@index([storeId])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  size      String
  color     String
  sku       String
  stock     Int      @default(0)
  price     Decimal
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([productId, size, color])
}

model Order {
  id              String      @id @default(cuid())
  storeId         String
  status          OrderStatus @default(PENDING)
  total           Decimal
  promoDiscount   Decimal     @default(0)
  shippingCost    Decimal     @default(0)
  customerName    String
  customerEmail   String
  customerPhone   String
  isPickup        Boolean     @default(false)
  shippingAddress String
  shippingCity    String
  shippingZip     String
  mpPreferenceId            String?
  mpPaymentId               String?
  confirmationEmailSentAt   DateTime?
  createdAt                 DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  store Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([storeId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int
  unitPrice Decimal

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])
}
